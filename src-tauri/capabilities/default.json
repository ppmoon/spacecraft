{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Privileged Host UI windows only — not Plugin surfaces",
  "windows": ["win-*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:webview:default",
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    "allow-open-blank-window",
    "allow-close-launcher",
    "allow-close-command-palette",
    "allow-list-plugins",
    "allow-open-plugin",
    "allow-propose-install",
    "allow-confirm-install",
    "allow-decline-install",
    "allow-pending-install"
  ]
}
